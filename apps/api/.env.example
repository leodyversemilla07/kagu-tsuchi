# Required
EXA_API_KEY=your_exa_api_key_here

# Optional - Server
PORT=3001
WEB_ORIGIN=http://localhost:3000

# Optional - LLM Synthesis (Agent 3)
SYNTHESIS_PROVIDER=auto  # "auto", "openai", "anthropic", or "openrouter"
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_SYNTHESIS_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_SYNTHESIS_MODEL=claude-3-5-haiku-latest
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_SYNTHESIS_MODEL=tencent/hy3-preview:free  # pi's default free model
